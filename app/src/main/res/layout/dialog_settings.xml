<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/action_settings"
        android:textColor="?attr/colorOnSurface"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- Desktop Site Preference Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Desktop Site"
                android:textColor="?attr/colorOnSurface"
                android:textSize="15sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Load desktop version of pages"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchDesktopMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Search Engine Section Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/search_engine_setting"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <!-- Search Engine Icons (Horizontal Scroll) -->
    <HorizontalScrollView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:layout_marginBottom="28dp">

        <LinearLayout
            android:id="@+id/llSearchEngines"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Google Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEngineGoogle"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_logo_google" />
            </com.google.android.material.card.MaterialCardView>

            <!-- DuckDuckGo Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEngineDuckDuckGo"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_logo_duckduckgo" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Bing Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEngineBing"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_logo_bing" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Ecosia Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEngineEcosia"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_logo_ecosia" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Custom Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEngineCustom"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivCustomEngine"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_add"
                    app:tint="?attr/colorOnSurface" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Clear Cache / Cookies Button (Styled as dynamic M3 tonal button) -->
    <Button
        android:id="@+id/btnClearData"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/clear_data"
        android:textColor="?attr/colorError"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        app:backgroundTint="?attr/colorSurfaceVariant" />

    <!-- About Button -->
    <Button
        android:id="@+id/btnAbout"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/about_bare"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="14sp" />

</LinearLayout>
