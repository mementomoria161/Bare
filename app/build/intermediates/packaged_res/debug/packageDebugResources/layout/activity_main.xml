<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".MainActivity">

    <!-- Fullscreen WebView container inside SwipeRefreshLayout -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/webViewContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?android:attr/windowBackground" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Dark semi-transparent dim overlay when Unprocess settings menu is active -->
    <View
        android:id="@+id/settingsDimOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Unprocess-style Pop-up Settings Stack (No clipping during overshoot animations) -->
    <LinearLayout
        android:id="@+id/settingsPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:visibility="gone"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/bottomBarCard"
        app:layout_constraintEnd_toEndOf="@id/bottomBarCard"
        android:layout_marginBottom="12dp">

        <!-- Horizontal Search Engine Row (Selector + Custom "+" Button) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Search Engine Selector (Cycles when clicked) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettingSearchEngine"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:text="Search Engine Google"
                android:textSize="15sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                app:icon="@drawable/ic_logo_google"
                app:iconPadding="8dp"
                app:iconSize="20dp"
                app:iconGravity="start"
                app:backgroundTint="?attr/colorSurfaceVariant"
                android:textColor="?attr/colorOnSurface"
                app:iconTint="?attr/colorOnSurface" />

            <!-- Add Custom Search Engine Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettingCustomSearch"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:icon="@drawable/ic_add"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:backgroundTint="?attr/colorSurfaceVariant"
                android:textColor="?attr/colorOnSurface"
                app:iconTint="?attr/colorOnSurface" />

        </LinearLayout>

        <!-- Desktop Mode Switch Button (Indicated via color state) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettingDesktopSite"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:text="Desktop View"
            android:textSize="15sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            app:icon="@drawable/ic_desktop"
            app:iconPadding="8dp"
            app:iconSize="20dp"
            app:iconGravity="start"
            app:backgroundTint="?attr/colorSurfaceVariant"
            android:textColor="?attr/colorOnSurface"
            app:iconTint="?attr/colorOnSurface" />
        <!-- Auto-Close Tabs Selector Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettingAutoClose"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:text="Auto-Close: Never"
            android:textSize="15sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            app:icon="@drawable/ic_clock"
            app:iconPadding="8dp"
            app:iconSize="20dp"
            app:iconGravity="start"
            app:backgroundTint="?attr/colorSurfaceVariant"
            android:textColor="?attr/colorOnSurface"
            app:iconTint="?attr/colorOnSurface" />

        <!-- Clear Cache/Cookies Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettingClearData"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="Clear Data"
            android:textColor="@android:color/holo_red_dark"
            android:textSize="15sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            app:icon="@drawable/ic_clear_all_thin"
            app:iconPadding="8dp"
            app:iconSize="20dp"
            app:iconGravity="start"
            app:backgroundTint="?attr/colorSurfaceVariant"
            app:iconTint="@android:color/holo_red_dark" />

    </LinearLayout>

    <!-- Inline Tab Overview Panel (Slides up above bottomBarCard, transparent background) -->
    <LinearLayout
        android:id="@+id/tabsPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBarCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp">

        <!-- RecyclerView for Tabs (scrolls fullscreen behind solid background) -->
        <com.mementomoria161.bare.FadingRecyclerView
            android:id="@+id/rvTabsInline"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:requiresFadingEdge="vertical"
            android:fadingEdgeLength="32dp" />

        <!-- FrameLayout container that acts as a solid mask for scrolling tab cards, matching dim overlay color -->
        <FrameLayout
            android:id="@+id/clearAllContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#B3000000"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="gone">

            <!-- Clear All Button styled as a settings button (centered at bottom) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearAllInline"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_gravity="center_horizontal"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:text="Clear All"
                android:textColor="@android:color/holo_red_dark"
                android:textSize="15sp"
                android:textStyle="bold"
                app:shapeAppearance="@style/ShapeAppearance.Bare.FAB"
                app:backgroundTint="?attr/colorSurfaceVariant"
                app:icon="@drawable/ic_clear_all_thin"
                app:iconTint="@android:color/holo_red_dark"
                app:iconSize="20dp"
                app:iconPadding="8dp" />
        </FrameLayout>
    </LinearLayout>

    <!-- Floating Bottom Bar Card (Adapted enclosing capsule) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomBarCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="40dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Border Progress Bar that outlines the capsule (matches card height/width) -->
        <com.mementomoria161.bare.CapsuleProgressView
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:indeterminate="false"
            android:max="100"
            android:visibility="gone" />

        <!-- Toolbar Container (Fills width, padding is 12dp all around for card spacing symmetry) -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- Address Bar Wrapper (Stretches with weight=1, fully rounded pill, height matches parent) -->
            <FrameLayout
                android:id="@+id/addressBarWrapper"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_address_bar">

                <EditText
                    android:id="@+id/addressInput"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_vertical"
                    android:gravity="start|center_vertical"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="56dp"
                    android:background="@null"
                    android:hint="@string/placeholder_search"
                    android:textColorHint="?attr/colorOnPrimaryContainer"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:importantForAutofill="no" />

                <ImageButton
                    android:id="@+id/btnRefresh"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center_vertical|end"
                    android:padding="16dp"
                    android:scaleType="fitCenter"
                    android:background="@drawable/bg_button"
                    android:contentDescription="Refresh page"
                    android:src="@drawable/ic_refresh"
                    app:tint="?attr/colorOnPrimaryContainer" />
            </FrameLayout>

            <!-- New Tab button (Floats on main screen next to URL bar, shown only on active sites, size 56dp) -->
            <ImageButton
                android:id="@+id/btnNewTabMain"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="0dp"
                android:padding="16dp"
                android:background="@drawable/bg_button"
                android:contentDescription="New tab"
                android:src="@drawable/ic_add_thin"
                android:visibility="gone"
                app:tint="?attr/colorOnSurfaceVariant" />

            <!-- Tab Overview Button Wrapper (Positioned left of Settings, size 56dp) -->
            <FrameLayout
                android:id="@+id/btnTabOverview"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="0dp"
                android:background="@drawable/bg_button"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_tabs"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/tvTabCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="1"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Settings Button (Far right position, size 56dp) -->
            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="0dp"
                android:padding="16dp"
                android:background="@drawable/bg_button"
                android:contentDescription="@string/action_settings"
                android:src="@drawable/ic_settings"
                app:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Border progress outlines bottomBarCard -->

</androidx.constraintlayout.widget.ConstraintLayout>
